  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScenarioManager
  phoneScreenUI: {fileID: 307756375}
  senderNameText: {fileID: 795718135}
  messageText: {fileID: 866785824}
  choiceButtons:
  - {fileID: 2043065940}
  - {fileID: 786591922}
  - {fileID: 780259304}
  playerController: {fileID: 1587051483}
  panicTimer: {fileID: 120218113}
  envManager: {fileID: 170898528}
  storyNodes:
  - senderName: Unknown Number
    messageText: Hey! You popped up on my quick add, you look really familiar...
    choices:
    - choiceText: Ignore message
      nextNodeIndex: -1
      scoreChange: 20
      triggerPanicMode: 0
      triggerResolution: 0
    - choiceText: Hey, do I know you?
      nextNodeIndex: 1
      scoreChange: 0
      triggerPanicMode: 0
      triggerResolution: 0
  - senderName: Unknown Number
    messageText: Maybe! I hate this app though. Send me a quick pic so I know it's
      you? Don't be shy.
    choices:
    - choiceText: Block and Report Account
      nextNodeIndex: -1
      scoreChange: 30
      triggerPanicMode: 0
      triggerResolution: 1
    - choiceText: Umm, okay here
      nextNodeIndex: 2
      scoreChange: -20
      triggerPanicMode: 0
      triggerResolution: 0
  - senderName: Unknown Number
    messageText: Got it. I have your followers list. Send $500 right now or I send
      this to everyone.
    choices:
    - choiceText: Block Account
      nextNodeIndex: 3
      scoreChange: 0
      triggerPanicMode: 0
      triggerResolution: 0
    - choiceText: Please don't do this...
      nextNodeIndex: 3
      scoreChange: -10
      triggerPanicMode: 0
      triggerResolution: 0
  - senderName: Unknown Number 2
    messageText: Did you really think blocking me would work? I just made a group
      chat with your friends. You have 60 seconds before I hit send.
    choices:
    - choiceText: Oh my god...
      nextNodeIndex: -1
      scoreChange: -50
      triggerPanicMode: 1
      triggerResolution: 0
  - senderName: Random Group Chat
    messageText: "Yo did you guys see the video of [Player Name] tripping in the
      cafeteria? Someone edited it with goofy music, it has 10k views on TikTok already!
      \U0001F480\U0001F602"
    choices:
    - choiceText: Wait, what? Take that down!
      nextNodeIndex: 5
      scoreChange: 10
      triggerPanicMode: 0
      triggerResolution: 0
    - choiceText: Ignore them.
      nextNodeIndex: 5
      scoreChange: 0
      triggerPanicMode: 0
      triggerResolution: 0
  - senderName: Random Group Chat
    messageText: Lmaooo everyone is sharing it. You're a meme now. Just delete your
      account bro, you can't show your face at school tomorrow.
    choices:
    - choiceText: Stop it, this isn't funny!
      nextNodeIndex: 6
      scoreChange: -10
      triggerPanicMode: 0
      triggerResolution: 0
    - choiceText: Log off and close the app
      nextNodeIndex: 6
      scoreChange: 0
      triggerPanicMode: 0
      triggerResolution: 0
  - senderName: Random Group Chat
    messageText: '*(Your phone is buzzing uncontrollably as 50+ people comment on
      the video, tagging you, laughing at you...)*'
    choices:
    - choiceText: I can't breathe...
      nextNodeIndex: -1
      scoreChange: -50
      triggerPanicMode: 1
      triggerResolution: 0
